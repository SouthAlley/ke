#!name=YouTube
#!desc=移除广告。
#!author=Maasea[https://github.com/Maasea/sgmodule], RuCu6[https://github.com/RuCu6]
#!icon=https://rucu6.pages.dev/Icons/app/youtube.png
#!date=2026-07-12 11:20
#!loon_version=3.4.0(962)
#!arguments=blockImmersive:false,blockShorts:false,blockUpload:false,debug:false,captionLang:"zh-Hans"
#!arguments-desc=blockImmersive: 隐藏选段按钮\n用于隐藏YouTube Music底栏的选段按钮\n\nblockShorts: 隐藏短片按钮\n用于隐藏YouTube Shorts按钮\n\nblockUpload: 隐藏上传按钮\n用于隐藏YouTube底栏的上传按钮\n\ndebug: 启用调试模式\n此插件的调试模式\n\ncaptionLang: 字幕翻译语言\n需要把YouTube字幕翻译翻译为何种语言

[URL Rewrite]
# youtube 短链移除追踪参数
(^https:\/\/youtu\.be\/[\w-]+)(?:\?si=\w+) $1 302

[Script]
youtube_request_init = type=http-request, pattern=^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&ack.*, script-path=https://rucu6.pages.dev/Scripts/youtube/request.js, requires-body=true, binary-body-mode=true, argument=captionLang="{{{captionLang}}}"

youtube_request_log_event = type=http-request, pattern=^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/log_event, script-path=https://rucu6.pages.dev/Scripts/youtube/request.js, requires-body=true, binary-body-mode=true

youtube_response = type=http-response, pattern=^https:\/\/youtubei\.googleapis\.com\/(?:youtubei\/v1\/(?:browse|config|log_event|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch))(\?(.*))?$, script-path=https://rucu6.pages.dev/Scripts/youtube/response.js, requires-body=true, binary-body-mode=true, argument=blockImmersive="{{{blockImmersive}}}"&blockShorts="{{{blockShorts}}}"&blockUpload="{{{blockUpload}}}"&debug="{{{debug}}}"&captionLang="{{{captionLang}}}"

[MITM]
hostname = %APPEND% rr*.googlevideo.com, youtu.be, youtubei.googleapis.com

